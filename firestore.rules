rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ USERS COLLECTION ============
match /users/{userId} {
  allow read: if request.auth != null;
  allow create: if request.auth != null && request.auth.uid == userId;
  // Allow users to update their own document
  allow update: if request.auth != null && request.auth.uid == userId;
  // Allow admins to update any user's document
  allow update: if request.auth != null && isAdmin();
}
    
    // ============ DEVICES COLLECTION ============
    match /devices/{deviceId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // ============ SHARE KEYS COLLECTION ============
    match /shareKeys/{shareKeyId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ============ CREDIT BURN RATES ============
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // ============ PLANS COLLECTION ============
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============ SITE CONTENT ============
    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============ PROMO CODES ============
    match /promoCodes/{promoId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ============ STATS COLLECTION ============
    match /stats/{statId} {
      allow read, write: if isAdmin();
    }
    
    match /hourlyStats/{statId} {
      allow read, write: if isAdmin();
    }
    
    match /monthlyStats/{statId} {
      allow read, write: if isAdmin();
    }
    
    // ============ ADMIN LOGS ============
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // ============ PENDING DEVICES ============
    match /pendingDevices/{pendingId} {
      allow create: if true;
      allow read, write: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // ============ DOCUMENTATION ============
    match /documentation/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============ SUPPORT TICKETS ============
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
// ============ CREDIT TRANSACTIONS ============
match /creditTransactions/{transactionId} {
  allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
  // Allow users to create their own credit transactions
  allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
  // Allow users to update their own credit transactions
  allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
  allow delete: if isAdmin();
}
    
    // ============ COMPILE JOBS ============
    match /compileJobs/{jobId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    // ============ NOTIFICATIONS COLLECTION ============
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
    }

    // ============ SETTINGS COLLECTION ============
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
