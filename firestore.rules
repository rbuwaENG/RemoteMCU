rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============ USERS COLLECTION ============
    // Users can read/write their own profile, admins can read all
    match /users/{userId} {
      // Owner can read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read all user profiles
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ DEVICES COLLECTION ============
    // Users can read/write their own devices, shared users can read
    match /devices/{deviceId} {
      // Allow any authenticated user to create
      allow create: if request.auth != null;
      
      // Allow read access broadly for development
      allow read: if request.auth != null;
      
      // Owner can write/delete their devices
      allow write, delete: if request.auth != null && 
        resource.data.ownerId == request.auth.uid;
      
      // Allow update if claiming unowned device
      allow update: if request.auth != null && 
        (resource.data.ownerId == null || resource.data.ownerId == request.auth.uid);
    }
    
    // ============ SHARE KEYS COLLECTION ============
    match /shareKeys/{shareKeyId} {
      // Only device owners can create/revoke share keys
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null && 
        resource.data.ownerId == request.auth.uid;
    }
    
    // ============ PLANS COLLECTION ============
    match /plans/{planId} {
      // Everyone can read plans (for display in pricing)
      allow read: if true;
      // Only admins can write plans
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ SITE CONTENT ============
    match /siteContent/{contentId} {
      // Everyone can read site content (landing page, about, etc.)
      allow read: if true;
      // Only admins can write site content
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ PROMO CODES ============
    match /promoCodes/{promoId} {
      // Admins can read all promo codes
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // Only admins can write promo codes
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ STATS COLLECTION ============
    match /stats/{statId} {
      // Only admins can read/write stats
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ ADMIN LOGS ============
    match /adminLogs/{logId} {
      // Only admins can read/write admin logs
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ PENDING DEVICES (for onboarding) ============
    match /pendingDevices/{pendingId} {
      // Allow anyone to create (host agent without auth)
      allow create: if true;
      // Device owner can read/write their pending device
      allow read, write: if request.auth != null && 
        resource.data.ownerId == request.auth.uid;
    }
    
    // ============ DOCUMENTATION COLLECTION ============
    match /documentation/{docId} {
      // Everyone can read documentation
      allow read: if true;
      // Only admins can write documentation
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ============ SUPPORT TICKETS ============
    match /supportTickets/{ticketId} {
      // Users can create tickets
      allow create: if request.auth != null;
      // Users can read their own tickets
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Users can update their own tickets, admins can update all
      allow update: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ============ CREDIT TRANSACTIONS ============
    match /creditTransactions/{transactionId} {
      // Users can read their own transactions, admins can read all
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Only system can create transactions (via Cloud Functions)
      allow create: if false;
      allow update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // ============ COMPILE JOBS (Phase 12) ============
    // Created by the browser, updated only by the host-agent via REST.
    match /compileJobs/{jobId} {
      // Only the owner can create a compile job
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      // Owner and admins can read job status/results
      allow read: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // No client-side updates — only the host-agent writes via REST (service account)
      allow update, delete: if false;
    }
  }
}